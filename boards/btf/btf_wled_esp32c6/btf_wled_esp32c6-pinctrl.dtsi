/*
 * SPDX-License-Identifier: Apache-2.0
 *
 * Same PCB as btf_wled_esp32, with the ESP32-C6-WROOM-1-N8 soldered onto
 * the WROOM-32E footprint (the 28 side castellations align pad-for-pad;
 * the 32E's 10 bottom pads are left open). The pads therefore keep their
 * old nets but carry new GPIO numbers:
 *
 *   silk CH1 (pad 12, was GPIO27) -> GPIO11
 *   silk CH2 (pad 11, was GPIO26) -> GPIO10
 *   silk CH3 (pad 10, was GPIO25) -> GPIO8   <-- C6 boot strap, see below
 *   button S1 (pad 25, was GPIO0) -> GPIO9   (the C6's boot pin: same
 *                                             hold-low-for-download semantics)
 *   UART0    (pads 34/35)         -> RXD=GPIO17, TXD=GPIO16
 *
 * GPIO8 strap caveat: entering serial download mode requires GPIO8=1 while
 * GPIO9 (button) is held low through reset. GPIO8 defaults to floating and
 * this pad drives a 74HC245 buffer input, so download-mode entry is
 * unreliable unless the rework adds a pull-up on the old-IO25/CH3 net (a
 * pull-up also turns the CH3 MOSFET on while the chip is in reset  -- an
 * acceptable blink for CCT boards where CH3 is unconnected). Normal SPI
 * boot ignores GPIO8.
 *
 * Channel numbering matches the classic board: LEDC ch0=CH1(cool),
 * ch1=CH2(warm), ch2=CH3, so the app's LEDCTRL_CH_* defaults hold.
 */

#include <zephyr/dt-bindings/pinctrl/esp-pinctrl-common.h>
#include <zephyr/dt-bindings/pinctrl/esp32c6-pinctrl.h>
#include <zephyr/dt-bindings/pinctrl/esp32c6-gpio-sigmap.h>

&pinctrl {
	uart0_default: uart0_default {
		group1 {
			pinmux = <UART0_TX_GPIO16>;
			output-high;
		};

		group2 {
			pinmux = <UART0_RX_GPIO17>;
			bias-pull-up;
		};
	};

	ledc0_default: ledc0_default {
		group1 {
			pinmux = <LEDC_CH0_GPIO11>,
				 <LEDC_CH1_GPIO10>,
				 <LEDC_CH2_GPIO8>;
			output-enable;
		};
	};
};
