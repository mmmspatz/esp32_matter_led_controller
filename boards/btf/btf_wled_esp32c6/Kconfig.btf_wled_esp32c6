# Zephyr 4.4 only defines the 1U (external antenna) module variants; the
# PCB-antenna ESP32-C6-WROOM-1-N8 on the reworked board is electrically
# identical (same die, same 8MB flash), so select the 1U-N8 symbol.
config BOARD_BTF_WLED_ESP32C6
	select SOC_ESP32_C6_WROOM_1U_N8
	select SOC_ESP32C6_HPCORE if BOARD_BTF_WLED_ESP32C6_ESP32C6_HPCORE
